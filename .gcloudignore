# Controls what `gcloud builds submit` uploads as the build context. When this
# file exists it REPLACES .gitignore for gcloud, so it must be comprehensive.
# Keep everything the Dockerfiles need (service source, pyproject files,
# frontend source + package-lock, packages/starter-template, templates).

.git/
.github/
.vscode/

# Python virtualenvs & caches
**/.venv/
**/venv/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/

# Node deps (reinstalled via `npm ci`)
**/node_modules/

# Regenerable / runtime artifacts
services/generation-service/var/
apps/web-client/var/
apps/web-client/staticfiles/
apps/web-client/games/static/games/dist/

# Reference-only project and local-only docs
codply/
.archive/
docs/local/

# Secrets & local env
**/.env
**/.env.*
!**/.env.example
