# ============================================================================
# Generation Service — environment configuration
# Copy to .env and fill in secrets. Every value has a working default for
# local development except the AI provider key.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
# Service name used in logs.
APP_NAME=generation-service
# Runtime environment: dev | staging | prod.
APP_ENV=dev
# Enables uvicorn auto-reload and verbose errors. Never true in prod.
APP_DEBUG=true
# Bind address for the HTTP server.
APP_HOST=0.0.0.0
# HTTP port of this service.
APP_PORT=8000
# Public origin of this service; used to build game play URLs returned by the API.
APP_PUBLIC_BASE_URL=http://localhost:8000
# Comma-separated browser origins allowed to call the API directly. The Django
# web client calls this service server-to-server, so CORS is not needed for it.
APP_CORS_ORIGINS=

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# console (human, dev) | json (structured, prod)
LOG_FORMAT=console

# ----------------------------------------------------------------------------
# AI access — built on the Anthropic SDK either way.
# openrouter (default): OpenRouter's Anthropic-compatible endpoint — one key,
#   many Claude models, ids like anthropic/claude-opus-4.8
# anthropic: the Anthropic API directly — ids like claude-opus-4-8
# ----------------------------------------------------------------------------
AI_PROVIDER=openrouter

# OpenRouter (used when AI_PROVIDER=openrouter). REQUIRED for generation.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic API key (used only when AI_PROVIDER=anthropic).
ANTHROPIC_API_KEY=

# Per-stage models (OpenRouter ids shown; use provider-native ids for direct providers).
# Cheap+fast for intake; Opus for the blueprint (small output, sets downstream
# quality); Sonnet for code — it emits the 8-15k-token game 2-3x faster than
# Opus, keeping a full pass + gate retries inside GENERATION_TIMEOUT_SECONDS.
# Cost lever: anthropic/claude-sonnet-5 on BLUEPRINT_MODEL is ~2.5x cheaper.
UNDERSTANDING_MODEL=anthropic/claude-haiku-4.5
BLUEPRINT_MODEL=anthropic/claude-opus-4.8
CODE_MODEL=anthropic/claude-sonnet-5

# Sampling temperature for all stages (code benefits from low-ish values).
LLM_TEMPERATURE=0.4
# Per-LLM-call timeout in seconds. Must cover a full code emission (~10k+
# output tokens), or slow calls die at the transport and get retried from
# scratch, burning the generation budget.
LLM_TIMEOUT_SECONDS=300
# Transport-level retries per LLM call (network/5xx), separate from gate retries.
LLM_MAX_RETRIES=4
# Output cap per structured call; code generation needs the headroom.
LLM_MAX_OUTPUT_TOKENS=32000

# ----------------------------------------------------------------------------
# Storage — game bundles (bodies). Metadata lives in the database.
# 'local' mirrors the future bucket layout on disk (games/{id}/index.html);
# 's3' is the post-MVP config swap behind the same StoragePort.
# ----------------------------------------------------------------------------
STORAGE_BACKEND=local
# Root folder for the local storage simulation (gitignored, regenerable).
STORAGE_LOCAL_DIR=var/storage

# Object storage (future; unused while STORAGE_BACKEND=local).
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
# Custom endpoint for S3-compatible stores (GCS interop, Cloudflare R2, MinIO).
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
# When set, play URLs point at this dedicated games origin instead of this
# service. Local dev runs the games-cdn static server on :8002 (make dev-cdn),
# which serves the same storage folder the way a bucket+CDN would.
CDN_BASE_URL=http://localhost:8002

# ----------------------------------------------------------------------------
# Database — Postgres. Metadata store (jobs, games, versions, LLM cost log);
# game bodies live in object storage, not here. Mirrors the web-client's
# POSTGRES_* convention. A full DATABASE_URL, if set, wins over the parts.
# Provision once (as a superuser) — see scripts/provision_db.sql:
#   CREATE ROLE gen_service LOGIN CREATEDB PASSWORD 'choose-a-password';
#   CREATE DATABASE generation_service OWNER gen_service;
# The test suite creates/drops its own throwaway databases per test, so the
# role needs CREATEDB; POSTGRES_MAINTENANCE_DB (default: postgres) is the db it
# connects to in order to issue those CREATE/DROP DATABASE statements.
# ----------------------------------------------------------------------------
# DATABASE_URL=postgresql://gen_service:password@localhost:5432/generation_service
POSTGRES_DB=generation_service
POSTGRES_USER=gen_service
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# asyncpg connection-pool bounds.
POOL_MIN_SIZE=1
POOL_MAX_SIZE=10

# ----------------------------------------------------------------------------
# Pipeline & quality gate
# ----------------------------------------------------------------------------
# Absolute or service-relative path to the versioned starter template package.
# Default resolves to <repo>/packages/starter-template.
#TEMPLATE_DIR=/absolute/path/to/packages/starter-template
# Code-generation retries after a gate failure (initial attempt + N retries).
GENERATION_MAX_CODE_RETRIES=2
# Hard wall-clock cap for one full generation job, in seconds. Sized for the
# worst case that should still succeed: blueprint + initial code attempt +
# GENERATION_MAX_CODE_RETRIES regenerations, each followed by gate + deep review.
GENERATION_TIMEOUT_SECONDS=900
# Concurrent pipeline runs; extra submissions wait in QUEUED order.
GENERATION_MAX_CONCURRENT=4
# Run `node --check` on generated JS (skipped gracefully when node is absent).
GATE_NODE_SYNTAX_CHECK=true
# Kill + skip the syntax check if node hangs past this many seconds.
GATE_SYNTAX_CHECK_TIMEOUT_SECONDS=20
# Boot each generated game headlessly (stubbed DOM + SDK, ~2 simulated seconds of
# frames and input) and reject games that crash. Skipped gracefully without node.
GATE_SMOKE_BOOT=true
# A game that can't finish the simulated frames within this budget is FAILED
# (it would freeze for every player) and the node process is reaped.
GATE_SMOKE_BOOT_TIMEOUT_SECONDS=30
# Size cap for generated game code (game.js + game.css), in KB.
GATE_MAX_GAME_KB=256

# ----------------------------------------------------------------------------
# Feature flags (future levers, off in the MVP)
# ----------------------------------------------------------------------------
# Deep logic review in the gate (LLM verifies core rule, solvability, AI-opponent
# quality against the blueprint; failures feed the retry loop). Kill switch.
FEATURE_LLM_REVIEW=true
# Chat-edit endpoint (POST /api/v1/games/{id}/tweaks): revise blueprint,
# regenerate code, re-run the gate, replace the game in place. Kill switch.
FEATURE_TWEAKS_API=true
# Public share tokens for games.
FEATURE_SHARE_LINKS=false

# ----------------------------------------------------------------------------
# Redis (future job broker; the MVP runs jobs in-process)
# ----------------------------------------------------------------------------
REDIS_URL=

# ----------------------------------------------------------------------------
# Security (future-ready placeholders; the MVP has no auth by design)
# ----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production
# Shared credential for future server-to-server callbacks.
SERVICE_TOKEN=

# --- Background painting (optional): full-scene backdrop via Gemini image gen ---
# With no key the pipeline skips painting; games use the procedural backdrop.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
FEATURE_BACKGROUND_ART=true
# Feed-card poster: a dedicated store-style cover (hero + the game's title
# lettered into the art) instead of reusing the empty backdrop. The title
# lettering is the hard part — set GEMINI_COVER_MODEL=gemini-3-pro-image
# ("Nano Banana Pro") for the crispest logos when the key has access.
GEMINI_COVER_MODEL=gemini-2.5-flash-image
FEATURE_COVER_POSTER=true
