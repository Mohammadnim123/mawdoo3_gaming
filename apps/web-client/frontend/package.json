{
  "name": "codply-web-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend build for the Django web client: Codply design-system CSS (Tailwind v4) + React islands (workspace, player/feed).",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/app.css -o ../games/static/games/dist/app.css --minify",
    "watch:css": "tailwindcss -i src/app.css -o ../games/static/games/dist/app.css --watch",
    "build": "npm run build:css && npm run build:islands",
    "build:islands": "vite build"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tailwindcss/cli": "^4.1.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-codemirror": "^4.25.11",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  }
}