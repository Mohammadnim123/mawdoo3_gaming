{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@codply/ui": ["./src/vendor/codply-ui/index.ts"],
      "@codply/game-runtime": ["./src/vendor/game-runtime/index.ts"],
      "@codply/contracts": ["./src/vendor/contracts/index.ts"],
      "next/link": ["./src/next-shim/link.tsx"],
      "next/navigation": ["./src/next-shim/navigation.ts"],
      "next/image": ["./src/next-shim/image.tsx"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
