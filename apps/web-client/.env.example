# ============================================================================
# Web Client (Django) — environment configuration
# Copy to .env. The client keeps NO state of its own: everything comes from
# the Generation Service REST API.
# ============================================================================

# Django secret key. Leave empty for local dev (a dev-only fallback applies
# while DJANGO_DEBUG=true); REQUIRED when DJANGO_DEBUG=false — the app
# refuses to start without it rather than sign cookies with a known value.
DJANGO_SECRET_KEY=

# Enables debug pages and static serving via runserver. Never true in prod
# (the code default is false; this file opts local dev in).
DJANGO_DEBUG=true

# Comma-separated hostnames Django will serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base URL of the Generation Service API (this client's ONLY backend).
GENERATION_API_URL=http://localhost:8000

# Timeout (seconds) for calls from Django to the generation service.
GENERATION_API_TIMEOUT_SECONDS=15

# ----------------------------------------------------------------------------
# Prompt validation LLM — the one AI call this client owns: before dispatch,
# the prompt is checked (is it a game? deliverable mini-game complexity?).
# Both providers run on the Anthropic SDK.
# ----------------------------------------------------------------------------

# openrouter | anthropic
VALIDATION_AI_PROVIDER=openrouter

# OpenRouter (used when VALIDATION_AI_PROVIDER=openrouter). REQUIRED for
# prompt validation — without it every generate attempt fails closed.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic API key (used only when VALIDATION_AI_PROVIDER=anthropic).
ANTHROPIC_API_KEY=

# Validation model. Mind the id dialect: OpenRouter 'anthropic/claude-haiku-4.5',
# direct Anthropic API 'claude-haiku-4-5'.
VALIDATION_MODEL=anthropic/claude-haiku-4.5

# Timeout (seconds) for the validation LLM call.
VALIDATION_TIMEOUT_SECONDS=30

# Default UI locale for the client chrome: ar | en (users can toggle).
WEB_DEFAULT_LOCALE=ar

# How many games the homepage lists (service caps at 100 per page).
GAMES_PAGE_SIZE=100

# Generation-progress polling cadence in milliseconds (JS poller + the
# noscript meta-refresh derive from this one value).
STATUS_POLL_INTERVAL_MS=3000
